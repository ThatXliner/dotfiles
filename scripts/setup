#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# Helper functions
# ---------------------------------------------------------------------------
info()    { echo "${fg[blue]}INFO: $*${fg[default]}"; }
error()   { echo "${fg[red]}ERROR: $*${fg[default]}"; }
warn()    { echo "${fg[yellow]}WARNING: $*${fg[default]}"; }
success() { echo "${fg[green]}SUCCESS: $*${fg[default]}"; }
with_color() { echo "${fg[$1]}$2${fg[default]}"; }
panic() { error "$1"; exit "${2:-1}"; }

# ---------------------------------------------------------------------------
# Phase 1 — Bootstrap
# ---------------------------------------------------------------------------
do_hushlogin() {
    if [ ! -f ~/.hushlogin ]; then
        info "1) Creating ~/.hushlogin"
        touch ~/.hushlogin
        success "1) Created ~/.hushlogin"
    else
        success "1) ~/.hushlogin already exists"
    fi
}

do_xcode_tools() {
    info "2) Installing Xcode command line tools"
    if xcode-select -p &>/dev/null; then
        success "2) Xcode command line tools already installed"
    else
        xcode-select --install || panic "2) Xcode command line tools installation failed"
        success "2) Xcode command line tools installation triggered"
    fi
}

clone_dotfiles() {
    info "3) Cloning dotfiles"
    if [ -d ~/dotfiles/.git ]; then
        success "3) Dotfiles already cloned"
    else
        git clone https://github.com/ThatXliner/dotfiles.git ~/dotfiles \
            || panic "3) Dotfiles failed to clone"
        success "3) Dotfiles cloned"
    fi
}

install_homebrew() {
    info "4) Installing Homebrew"
    if command -v brew &>/dev/null; then
        success "4) Homebrew already installed"
    else
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        if [[ "$(uname -m)" == "arm64" ]]; then
            BREW_PREFIX="/opt/homebrew"
        else
            BREW_PREFIX="/usr/local"
        fi
        (echo; echo "eval \"\$(${BREW_PREFIX}/bin/brew shellenv)\"") >> ~/.zprofile
        eval "$(${BREW_PREFIX}/bin/brew shellenv)"
        success "4) Homebrew installed"
    fi
}

install_antidote() {
    info "5) Installing Antidote"
    if [ -d "${ZDOTDIR:-$HOME}/.antidote" ]; then
        success "5) Antidote already installed"
    else
        git clone --depth=1 https://github.com/mattmc3/antidote.git "${ZDOTDIR:-$HOME}/.antidote" \
            || panic "5) Antidote failed to install"
        success "5) Antidote installed"
    fi
}

install_rust() {
    info "6) Installing Rust"
    if command -v rustup &>/dev/null; then
        success "6) Rust already installed"
    else
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
        success "6) Rust installed"
    fi
}

# ---------------------------------------------------------------------------
# Phase 2 — Tools
# ---------------------------------------------------------------------------
brew_bundle() {
    info "7) Installing Homebrew packages"
    brew bundle install --file=$HOME/dotfiles/Brewfile || panic "7) Homebrew bundle installation failed"
    success "7) Homebrew packages installed"
}

install_python_tools() {
    info "8) Installing Python tools via uv"
    # Tools not available on Homebrew
    for tool in copier git-worm codeberg-cli; do
        uv tool install "$tool" 2>/dev/null || warn "8) Error, skipping installation of $tool (non-fatal)"
    done
    uv tool install ipython --with hid --with pyautogui --with sympy --with numpy --with pandas --with matplotlib --with requests --with aiohttp 2>/dev/null || true
    success "8) Python tools installed"
}

install_npm_tools() {
    info "9) Installing npm tools via Bun"
    for tool in trash-cli @antfu/ni localtunnel; do
        bun install -g "$tool" 2>/dev/null || warn "9) Error, skipping installation of $tool (non-fatal)"
    done
    success "9) npm tools installed"
}

install_cargo_tools() {
    info "10) Installing Rust tools via cargo"
    for tool in rtk cargo-binstall; do
        cargo install "$tool" 2>/dev/null || warn "10) Error, skipping installation of $tool (non-fatal)"
    done
    cargo install --git https://github.com/ThatXliner/rt 2>/dev/null || true
    success "10) Rust tools installed"
}

# ---------------------------------------------------------------------------
# Phase 3 — Config
# ---------------------------------------------------------------------------
setup_config() {
    info "11) Setting up config files"
    [ ! -f ~/.gitconfig ] && cp ~/dotfiles/.gitconfig ~/.gitconfig

    info "11a) GPG commit signing"
    if gum confirm "Should we sign commits with GPG?"; then
        if ! command -v gpg &>/dev/null; then
            panic "Please install GPGTools (https://gpgtools.org/) and re-run"
        fi
        git config --global commit.gpgsign true
        git config --global user.signingkey \
            "$(gum input --prompt 'Your GPG key ID: ' --placeholder 'Get it from: gpg --list-secret-keys --keyid-format=long')"
    fi

    info "11b) Setting up Zsh prompt"
    ln -sf ~/dotfiles/prompts/single.zsh ~/.p10k.zsh

    success "11) Config files set up"
}

# ---------------------------------------------------------------------------
# Phase 4 — Shell
# ---------------------------------------------------------------------------
reset_zshrc() {
    info "12) Setting up ~/.zshrc"
    echo "source $HOME/dotfiles/zshrc/index.zsh" > ~/.zshrc
    # shellcheck disable=SC1090
    source ~/.zshrc
    success "12) ~/.zshrc set up"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    setopt interactivecomments
    autoload -U colors && colors

    with_color blue '
___________.__            __ ____  ___.____    .__                   /\
\__    ___/|  |__ _____ _/  |\   \/  /|    |   |__| ____   __________)/ ______
  |    |   |  |  \\__  \\   __\     / |    |   |  |/    \_/ __ \_  __ \/  ___/
  |    |   |   Y  \/ __ \|  | /     \ |    |___|  |   |  \  ___/|  | \/\___ \
  |____|   |___|  (____  /__|/___/\  \|_______ \__|___|  /\___  >__|  /____  >
                \/     \/          \_/        \/       \/     \/           \/
'
    with_color green '
    ____          __   ____ _  __
   / __ \ ____   / /_ / __/(_)/ /___   _____
  / / / // __ \ / __// /_ / // // _ \ / ___/
 / /_/ // /_/ // /_ / __// // //  __/(__  )
/_____/ \____/ \__//_/  /_//_/ \___//____/

    ____              __          __ __
   /  _/____   _____ / /_ ____ _ / // /
   / / / __ \ / ___// __// __ `// // /
 _/ / / / / /(__  )/ /_ / /_/ // // /
/___//_/ /_//____/ \__/ \__,_//_//_/

   _____              _         __
  / ___/ _____ _____ (_)____   / /_
  \__ \/ ___// ___// // __ \ / __/
 ___/ / /__ / /   / // /_/ // /_
/____/\___//_/   /_// .___/ \__/
                   /_/
'
    with_color magenta "In a few moments, we'll set up your development environment"
    with_color magenta "This will take a while, so grab a coffee or something"
    with_color magenta "(Press Ctrl+C to cancel)"
    with_color yellow '"I hope you have as much fun using my dotfiles as I had making them!" - ThatXliner'

    # Phase 1 — Bootstrap (run parallel-safe steps in background)
    do_hushlogin
    do_xcode_tools
    clone_dotfiles
    install_homebrew &
    install_antidote &
    install_rust &
    wait

    # Ensure cargo is on PATH after rustup install
    [[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

    # Phase 2 — Tools
    brew_bundle
    install_python_tools &
    install_npm_tools &
    install_cargo_tools &
    wait

    # Phase 3 — Config
    setup_config

    # Phase 4 — Shell
    reset_zshrc

    success 'All done! Enjoy your new development environment!'
}
main
